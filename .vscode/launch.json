{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "julia",
            "request": "launch",
            "name": "Launch Julia tests",
            "program": "${workspaceFolder}/test/runtests.jl",
            "stopOnEntry": true
        },
        {
            "type": "julia",
            "request": "launch",
            "name": "Oslofjord",
            "program": "${workspaceFolder}/examples/oslofjord.jl",
            "stopOnEntry": false,
            "juliaAdditionalArgs": [
                "-O0"
            ]
        },
        {
            "type": "julia",
            "request": "launch",
            "name": "bathymetry_prepare",
            "program": "${workspaceFolder}/scripts/bathymetry_prepare.jl",
            "stopOnEntry": false,
            "juliaAdditionalArgs": [
                "-O0"
            ]
        },
        {
            "type": "julia",
            "request": "launch",
            "name": "download norkyst",
            "program": "${workspaceFolder}/scripts/forcing_download_norkyst.jl",
            "stopOnEntry": false,
            "juliaAdditionalArgs": [
                "--project=${workspaceFolder}",
                "-O0"
            ],
            "env": {
                "FJORDSIM_RUN_MAIN": "1"
            },
            "args":[
                "--year",
                "2020",
                "--output-dir",
                "~/FjordSim_data/drammensfjorden"
            ]
        },
    ]
}

    "version": "0.2.0",
    "configurations": [
        {
            "type": "julia",
            "request": "launch",
            "name": "Launch Julia tests",
            "program": "${workspaceFolder}/test/runtests.jl",
            "stopOnEntry": true
        },
        {
            "type": "julia",
            "request": "launch",
            "name": "Oslofjord",
            "program": "${workspaceFolder}/examples/oslofjord.jl",
            "stopOnEntry": false,
            "juliaAdditionalArgs": [
                "-O0"
            ]
        },
        {
            "type": "julia",
            "request": "launch",
            "name": "bathymetry_prepare",
            "program": "${workspaceFolder}/scripts/bathymetry_prepare.jl",
            "stopOnEntry": false,
            "juliaAdditionalArgs": [
                "-O0"
            ]
        },
    ]
}